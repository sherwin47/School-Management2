{
  "name": "school-management-erp-backend",
  "version": "1.0.0",
  "description": "Scalable school management ERP backend",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rimraf dist && prisma generate && tsc",
    "start": "tsx src/server.ts",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "seed": "tsx src/scripts/seed.ts",
    "migrate:school-admins": "tsx src/scripts/migrate-school-admin-users.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "@types/ws": "^8.18.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "helmet": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.6.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.10",
    "pdfmake": "^0.3.9",
    "socket.io": "^4.8.3",
    "twilio": "^6.0.2",
    "ws": "^8.21.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.16.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfmake": "^0.3.3",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.15.0",
    "prettier": "^3.6.2",
    "prisma": "^6.15.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0"
  }
}
